# Backend Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/azurebuilder
REDIS_URL=redis://localhost:6379/0
DEBUG=false
ENVIRONMENT=production
JWT_SECRET_KEY=change-me-to-a-secure-random-string
CORS_ORIGINS=https://yourdomain.com

# Azure Configuration
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/
AZURE_SERVICE_BUS_CONNECTION_STRING=your-service-bus-connection-string

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_API_KEY=your-openai-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4-turbo

# Azure AD B2C (Authentication)
AZURE_AD_B2C_TENANT=your-b2c-tenant
AZURE_AD_B2C_CLIENT_ID=your-b2c-client-id

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
